# The Makefile is generated by AI in such a way 
# that it can be dynamically expanded later to include the ball and animal

CC = gcc
CFLAGS = -Iinclude -Wall -Wextra -Wpedantic
LDFLAGS = -lmingw32 -lSDL2main -lSDL2 -lSDL2_image -lopengl32 -lm

SRCS = src/main.c \
       src/app.c \
       src/camera.c \
       src/scene.c \
       src/utils.c \
       src/pendulum.c \
       src/bouncing_ball.c

OBJS = $(SRCS:.c=.o)

TARGET = anim.exe

all: $(TARGET)

$(TARGET): $(OBJS)
	$(CC) -o $@ $^ $(LDFLAGS)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	del /Q src\*.o $(TARGET) 2>nul || rm -f src/*.o $(TARGET)

.PHONY: all clean